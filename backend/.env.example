# Copy this file to .env and fill in real values for production.
# Never commit .env to git. The defaults let the app run locally in dry-run mode.

ENVIRONMENT=development
SECRET_KEY=change-me
GITHUB_WEBHOOK_SECRET=dev-webhook-secret

# Required for real GitHub webhook reviews.
GITHUB_TOKEN=

# Required for Claude reviews. If empty, local heuristic review is used when DRY_RUN_WITHOUT_AI=true.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
DRY_RUN_WITHOUT_AI=true

# SQLite is easiest locally. Use PostgreSQL in production if desired.
DATABASE_URL=sqlite:///./ai_code_reviewer.db
